# Пример переменных окружения для работы с API aaPanel.
# Скопируй в .env и подставь свои значения. .env в git НЕ попадает (см. .gitignore).
# ВНИМАНИЕ: это секреты. Используются ТОЛЬКО на стороне сервера.

# Базовый адрес панели: протокол + хост + порт, без слэша в конце.
# Для авторизации ключом — КОРЕНЬ, без защитного входа и без apsess.
AAPANEL_BASE_URL=https://<СЕРВЕР>:<ПОРТ>

# --- Способ 1: постоянный ключ api_sk (рекомендуется для приложений) ---
# Настройки → API → сгенерировать ключ + добавить IP в whitelist.
AAPANEL_API_SK=<API_SK>

# --- Способ 2: сессия браузера (временная, для разведки) ---
# Не нужны, если используешь api_sk. Подробнее — docs/ru/authentication.md
# AAPANEL_SESSION_TOKEN=apsess_XXXXXXXXXXXXXXXXXXXX
# AAPANEL_HTTP_TOKEN=<X_HTTP_TOKEN>
# AAPANEL_COOKIE=<COOKIE_NAME>=<COOKIE_VALUE>

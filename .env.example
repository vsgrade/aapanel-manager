# Пример переменных окружения для работы с API aaPanel.
# Скопируй в .env и подставь свои значения. .env в git НЕ попадает (см. .gitignore).
# ВНИМАНИЕ: эти значения — секреты. Используются только на стороне сервера.

# Базовый адрес панели: протокол + хост + порт (без слэша в конце)
AAPANEL_BASE_URL=https://<СЕРВЕР>:<ПОРТ>

# Сессионный токен из адресной строки браузера (apsess_...).
# ВРЕМЕННЫЙ: меняется при перелогине / истекает. Подробнее — docs/ru/authentication.md
AAPANEL_SESSION_TOKEN=apsess_XXXXXXXXXXXXXXXXXXXXXXXX

# Постоянный API-ключ официального API (Настройки → API). Опционально.
# AAPANEL_API_SK=
